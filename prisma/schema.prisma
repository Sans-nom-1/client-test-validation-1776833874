// Prisma schema for LVL UP - Salon booking system
// Database: Supabase (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Salon entity
model Salon {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  timezone  String   @default("Europe/Paris")
  settings  String?  // JSON string for flexible settings (opening hours, booking rules, etc.)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff             Staff[]
  services          Service[]
  customers         Customer[]
  appointments      Appointment[]
  visits            Visit[]
  smsLogs           SmsLog[]
  consentLogs       ConsentLog[]
  pushSubscriptions PushSubscription[]
  waitingList      WaitingList[]
  cancellationLogs CancellationLog[]

  @@map("salons")
}

// Staff/Team members
model Staff {
  id           String   @id @default(cuid())
  salonId      String
  name         String
  email        String?  @unique
  passwordHash String?  // For admin authentication
  role         String @default("STAFF") // ADMIN or STAFF
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  salon         Salon              @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  visits        Visit[]
  availability  StaffAvailability[]

  @@index([salonId])
  @@map("staff")
}

// Staff availability/schedule
model StaffAvailability {
  id        String   @id @default(cuid())
  staffId   String
  date      DateTime // Specific date for this availability
  startTime String   // Format: "09:00"
  endTime   String   // Format: "19:00"
  isBlocked Boolean  @default(false) // true = congé/indisponible, false = disponible
  reason    String?  // Optional reason for blocking (congé, formation, etc.)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([date])
  @@map("staff_availability")
}

// StaffRole: "ADMIN" or "STAFF"

// Services/Prestations
model Service {
  id          String   @id @default(cuid())
  salonId     String
  name        String
  description String?
  durationMin Int      // Duration in minutes
  price       Float?   // Indicative price
  category    String   @default("PRESTATION") // PRESTATION or PACK
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  salon        Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([salonId])
  @@map("services")
}

// Customers/Clients
model Customer {
  id             String    @id @default(cuid())
  salonId        String
  firstName      String
  lastName       String
  phone          String
  email          String?
  dateOfBirth    DateTime? // Date de naissance
  passwordHash   String?   // For email/password auth
  marketingOptIn Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  salon            Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointments      Appointment[]
  visits            Visit[]
  consentLogs       ConsentLog[]
  waitingList       WaitingList[]
  cancellationLogs  CancellationLog[]
  reviews           Review[]
  pushSubscriptions PushSubscription[]

  @@unique([salonId, phone])
  @@index([salonId])
  @@index([salonId, createdAt])
  @@index([email])
  @@map("customers")
}

// Appointments/Rendez-vous
model Appointment {
  id                 String            @id @default(cuid())
  salonId            String
  customerId         String
  staffId            String?
  serviceId          String
  startAt            DateTime
  endAt              DateTime
  status             String @default("BOOKED") // BOOKED, CANCELLED, NO_SHOW, DONE
  notes              String?
  confirmationSmsSent Boolean          @default(false)
  confirmationSmsAt   DateTime?
  reminderSmsSent     Boolean          @default(false)
  reminderSmsAt       DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  salon            Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  staff            Staff?            @relation(fields: [staffId], references: [id], onDelete: SetNull)
  service          Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  visits           Visit[]
  cancellationLogs CancellationLog[]

  @@index([salonId])
  @@index([customerId])
  @@index([staffId])
  @@index([startAt])
  @@index([status])
  @@index([reminderSmsSent, startAt])
  @@map("appointments")
}

// AppointmentStatus: "BOOKED", "CANCELLED", "NO_SHOW", "DONE"

// Visits/Historique (generated when appointment is marked as DONE)
model Visit {
  id              String   @id @default(cuid())
  salonId         String
  customerId      String
  appointmentId   String?
  occurredAt      DateTime
  serviceSnapshot String?  // JSON string of service details at time of visit
  amount          Float?
  createdByStaffId String?
  createdAt       DateTime @default(now())

  salon       Salon        @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdBy   Staff?       @relation(fields: [createdByStaffId], references: [id], onDelete: SetNull)

  @@index([salonId])
  @@index([customerId])
  @@index([customerId, occurredAt])
  @@index([occurredAt])
  @@map("visits")
}

// SMS Logs
model SmsLog {
  id                String   @id @default(cuid())
  salonId           String
  customerId        String?
  phone             String
  type              String   // CONFIRMATION, REMINDER, CANCELLATION, MARKETING
  payload           String   // JSON string of SMS content + metadata
  status            String   // SENT, FAILED, PENDING
  provider          String   @default("brevo")
  providerMessageId String?
  createdAt         DateTime @default(now())

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@index([customerId])
  @@index([type])
  @@index([createdAt])
  @@map("sms_logs")
}

// SmsType: "CONFIRMATION", "REMINDER", "CANCELLATION", "MARKETING"
// SmsStatus: "SENT", "FAILED", "PENDING"

// Consent tracking (RGPD compliance)
model ConsentLog {
  id         String      @id @default(cuid())
  salonId    String
  customerId String
  type       String      // MARKETING, SMS_REMINDERS
  value      Boolean
  source     String?     // e.g., "booking_form", "profile_page"
  createdAt  DateTime    @default(now())

  salon    Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@index([customerId])
  @@map("consent_logs")
}

// ConsentType: "MARKETING", "SMS_REMINDERS"

// Waiting list for when customer wants to be notified of availability
model WaitingList {
  id          String    @id @default(cuid())
  salonId     String
  customerId  String
  createdAt   DateTime  @default(now())
  notes       String?
  status      String    @default("ACTIVE") // ACTIVE, CONTACTED, CONVERTED
  contactedAt DateTime?
  contactedBy String?

  salon    Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@index([customerId])
  @@index([status])
  @@map("waiting_list")
}

// WaitingListStatus: "ACTIVE", "CONTACTED", "CONVERTED"

// Log of cancelled appointments for tracking customer behavior
model CancellationLog {
  id              String   @id @default(cuid())
  appointmentId   String
  customerId      String
  salonId         String
  cancelledAt     DateTime @default(now())
  cancelledBy     String   // CUSTOMER or ADMIN
  reason          String?
  hoursBeforeAppt Float
  originalStartAt DateTime

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  salon       Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@index([customerId])
  @@map("cancellation_logs")
}

// CancelledBy: "CUSTOMER", "ADMIN"

// Verification codes for phone verification and password reset
model VerificationCode {
  id        String   @id @default(cuid())
  phone     String
  code      String   // 6-digit code
  type      String   // PHONE_VERIFICATION or PASSWORD_RESET
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, type])
  @@index([expiresAt])
  @@map("verification_codes")
}

// VerificationCodeType: "PHONE_VERIFICATION", "PASSWORD_RESET"

// Web Push subscriptions
model PushSubscription {
  id         String   @id @default(cuid())
  salonId    String
  customerId String?
  endpoint   String   @unique
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())

  salon    Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([salonId])
  @@index([customerId])
  @@map("push_subscriptions")
}

// Customer reviews/avis
model Review {
  id         String   @id @default(cuid())
  salonId    String
  customerId String
  rating     Int      // 1-5
  comment    String?
  adminReply String?  // Réponse de l'admin
  adminReplyAt DateTime? // Date de la réponse
  isApproved Boolean  @default(true) // Auto-approved now
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@index([customerId])
  @@index([isApproved])
  @@map("reviews")
}
